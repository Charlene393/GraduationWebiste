{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@graduaro/api": "workspace:*",
    "@graduaro/auth": "workspace:*",
    "@graduaro/db": "workspace:*",
    "@graduaro/env": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@graduaro/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
